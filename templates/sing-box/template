# Template file for 'sing-box'
pkgname=sing-box
version=1.13.2
revision=1
archs="i686* x86_64* aarch64*"
build_style=gnu-makefile
make_build_args="VERSION=${version} GOFLAGS=-buildmode=pie"
hostmakedepends="go"
short_desc="Universal proxy platform"
maintainer="Orphaned <orphan@voidlinux.org>"
license="GPL-3.0-or-later"
homepage="https://sing-box.sagernet.org"
distfiles="https://github.com/SagerNet/sing-box/archive/refs/tags/v${version}.tar.gz"
checksum=04b72fcd355c36a85eb028f47986894e9cf4dadbea3fee79f6891481cabeb692

system_accounts="_sing_box"
_sing_box_homedir="/var/lib/sing-box"
make_dirs="/etc/sing-box 0755 root root"

do_install() {
	vbin $pkgname
	vsv $pkgname
	vsconf release/config/config.json
}
