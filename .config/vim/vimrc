set number
set relativenumber
set cursorline
set encoding=utf-8
set fileencoding=utf-8
set nocompatible
set incsearch
set scrolloff=8
set sidescrolloff=5
set ignorecase
set showcmd
set showmatch
set wildmenu
set wildmode=list:longest
set showmode
set hlsearch
set nobackup
setlocal noswapfile
set history=1000
set lazyredraw
set ruler
set title
set laststatus=2
set smartindent
syntax on
filetype plugin indent on
set viminfofile=~/.config/vim/viminfo
set cmdheight=1
set modeline
set modelines=1
set matchtime=2
set backupcopy=yes
set tabstop=4
set shiftwidth=4
set softtabstop=4
set expandtab
set matchtime=2
set autochdir
set foldenable
set foldmethod=manual
set foldcolumn=0
setlocal foldlevel=1
nnoremap <space> @=((foldclosed(line('.')) < 0) ? 'zc' : 'zo')<CR>
set statusline=\ %<%F\ [%1*%M%*%n%R%H]%=\ %y\ %0(%{&fileformat}\ %{&encoding}\ Ln\ %l,\ Col\ %c/%L%)
set splitbelow
set splitright
packadd! editorconfig
