-o "~/Videos/yt-dlp/%(title)s.%(ext)s"
--cookies-from-browser firefox
--write-subs
--write-auto-subs
--sub-langs "zh-Hans,en-orig,ja"
--embed-subs
--embed-metadata
--embed-thumbnail
--embed-chapters
--compat-options no-keep-subs
--js-runtimes node
--socket-timeout 25
--retries 4
--fragment-retries 4
--restrict-filenames
--limit-rate 2M
--concurrent-fragments 6
--merge-output-format mkv
--audio-format m4a
--remux-video "m4a>mka/mkv"
--sleep-interval 5
--max-sleep-interval 12
--progress-template "Download:[%(info.title).35s...] %(progress._percent_str)s | Speed: %(progress._speed_str)s | ETA: %(progress._eta_str)s"
--progress
--quiet
